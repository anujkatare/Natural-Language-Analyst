ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1053, CodeContent of Pipfile.lock should be committed unless
#   it is a library. However, check it in if you are building an application.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, Poetry manage_tasks dev-dependencies in poetry.lock, which should be committed
#   unless it's a library.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm manage_tasks dev-dependencies in pdm.lock, which should be committed
#   unless it's a library.
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
./env/
./venv/

